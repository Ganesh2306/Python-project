pipeline {

    agent any
    environment {
        AWS_ACCESS_KEY_ID     = credentials('aws-creds')
        AWS_SECRET_ACCESS_KEY = credentials('aws-creds')
    }    
    stages {

        stage('Clone Repo') {
            steps {

                git(
                    branch: 'main',
                    url: 'https://github.com/Ganesh2306/Python-project.git'
                )

            }
        }

        stage('Check Files') {
            steps {
                sh 'ls -la'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t python-devops ./app/python-app'
            }
        }

        stage('Terraform Init') {
            steps {
                sh 'cd terraform && terraform init'
            }
        }

        stage('Update Inventory') {
            steps {
                sh '''
                IP=$(cd terraform && terraform output -raw instance_public_ip)
                echo "[web]" > ansible/inventory.ini
                echo "$IP ansible_user=ubuntu ansible_ssh_private_key_file=devops-key.pem" >> ansible/inventory.ini
                '''
            }
        }

        stage('Terraform Apply') {
            steps {
                sh 'cd terraform && terraform apply -auto-approve'
            }
        }

        stage('Deploy using Ansible') {
            steps {
                sh '''
                export ANSIBLE_HOST_KEY_CHECKING=False
                ansible-playbook -i ansible/inventory.ini ansible/setup.yml
                '''
            }
        }

    }
}